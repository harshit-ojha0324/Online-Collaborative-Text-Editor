# Copy to .env.local (or set in your deploy environment) to point the frontend at a backend.
# Both fall back to localhost defaults when unset, so local development needs no .env file.

# REST API base URL (no trailing slash)
VITE_API_URL=http://localhost:3000

# STOMP-over-WebSocket endpoint
VITE_WS_URL=ws://localhost:3000/docs/ws
